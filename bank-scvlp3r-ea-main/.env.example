# Environment Variables for BANK SCALPER EA

# Supabase Configuration (Required for app functionality)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# AI Service Configuration (Required for signal generation)
LOVABLE_API_KEY=your_lovable_api_key

# Instructions:
# 1. Copy this file to .env.local for local development
# 2. Set these environment variables in your Vercel project settings
# 3. For Supabase functions, deploy them separately to Supabase Edge Functions
#    or configure Vercel to proxy to your Supabase project